{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "outDir": "dist",
    "rootDir": "src",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ES2019",
    "removeComments": false,
    "allowImportingTsExtensions": false,
    "jsx": "react-jsx"
  },
  "include": ["src/index.ts", "src/blobScene.ts", "src/react/MetallicBlob.tsx", "src/shims.d.ts"]
}

